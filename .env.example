# ── Telegram ────────────────────────────────────────────────────────────────
# Get these from @BotFather on Telegram.
# 1. Create a bot: /newbot in @BotFather → copy the token
# 2. Add the bot to your channel/group and send a message
# 3. Fetch your chat_id: https://api.telegram.org/bot<token>/getUpdates
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ── Finnhub (optional — better news headlines; Yahoo fallback if unset) ─────
# Free key: https://finnhub.io/register
FINNHUB_API_KEY=

# ── Gap scan filters ─────────────────────────────────────────────────────────
GAP_MIN_PCT=3.0          # minimum gap % vs previous close
MIN_PRICE=3.0            # minimum share price ($)
MAX_RESULTS=20           # cap the alert list

# ── Trade plan ────────────────────────────────────────────────────────────────
STOP_PCT_BELOW_PMH=1.0   # stop = premarket high − 1%

# ── Data fetching ─────────────────────────────────────────────────────────────
BATCH_SIZE=50            # symbols per yfinance batch download
NEWS_MAX_AGE_HOURS=48    # catalyst headline freshness window
